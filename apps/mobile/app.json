{
  "expo": {
    "name": "Syncrolly",
    "slug": "syncrolly",
    "scheme": "syncrolly",
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Syncrolly to access your photo library so you can choose a profile photo.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Syncrolly to access your microphone for voice assistant conversations."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "70a92735-e2d7-460e-a293-cc2335c6b274"
      }
    }
  }
}
